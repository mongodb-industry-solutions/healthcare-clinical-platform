FROM node:22-alpine
WORKDIR /app

ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

ARG NEXT_PUBLIC_CHARTS_BASE_URL
ENV NEXT_PUBLIC_CHARTS_BASE_URL=${NEXT_PUBLIC_CHARTS_BASE_URL}

ARG NEXT_PUBLIC_CHARTS_CARE_GAP_DASHBOARD_ID
ENV NEXT_PUBLIC_CHARTS_CARE_GAP_DASHBOARD_ID=${NEXT_PUBLIC_CHARTS_CARE_GAP_DASHBOARD_ID}

COPY frontend/package*.json ./
RUN npm install
COPY frontend/ .

RUN npm run build
EXPOSE 8080
CMD ["npm", "start"]